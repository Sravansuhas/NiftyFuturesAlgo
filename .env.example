# Zerodha Kite Connect credentials (never commit real values)
KITE_API_KEY=
KITE_API_SECRET=

# Must match Redirect URL in Kite developer console (NOT Postback URL)
KITE_REDIRECT_URL=http://127.0.0.1:8765/callback

# Daily access token (generate via generate_token.py before market open)
KITE_ACCESS_TOKEN=
KITE_REFRESH_TOKEN=

# Safety: when true, ALL orders are simulated even in LIVE_MODE. Keep true until full validation.
FORCE_DRY_RUN=true

# Engine toggles — prefer Settings → Trading Controls in the web portal (no restart).
# Portal saves to data/trading_controls.json and overrides these when set.
# FUTURES_TRADING_ENABLED=false
# OPTIONS_TRADING_ENABLED=false
# OPTIONS_EOD_FLATTEN=true

# Options cycle interval (seconds) — YAML/env only for now
# OPTIONS_STRATEGY_INTERVAL=300

# SEBI algo order tag (alphanumeric, max 20 chars). Applied to every Kite order.
ALGO_ID=AEGIS

# Optional: document VPS static outbound IP for compliance audit log
# STATIC_OUTBOUND_IP=

# Optional Postgres mirror (JSONL remains default source of truth)
# DATABASE_URL=postgresql://trading:trading123@localhost:5432/trading
# PERSISTENCE_BACKEND=jsonl   # jsonl | dual | postgres

# WebSocket feed (threaded KiteTicker — recommended over REST polling)
# ENABLE_WEBSOCKET=true
# ENABLE_WS_QUOTE=true        # MODE_QUOTE for volume/OI → candle_builder

# Trade ledger: persisted at data/trade_ledger.jsonl (survives restarts by default)
# CLEAR_LEDGER_ON_START=true   # archives old ledger and starts fresh (demo only)
# ENGINE_IDLE_WHEN_CLOSED=true # skip signal checks when market closed (default on)

# EOD MIS flatten before Zerodha auto square-off (regime-aware defaults):
#   before 2026-08-03: 15:10–15:15 | on/after: 15:20–15:25 (NSE close 15:40)
# EOD_MIS_FLATTEN=true
# EOD_FLATTEN_START=15:10
# EOD_FLATTEN_END=15:15

# Optional: override risk capital (default 10L in RiskGatekeeper)
# RISK_CAPITAL=1000000
